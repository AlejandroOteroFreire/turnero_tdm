# ============================================================
# Variables de entorno — copiar a .env.local para desarrollo
# ============================================================

# Supabase (valores del `npx supabase status`)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth (Supabase Dashboard → Auth → Providers)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# WhatsApp Cloud API (Meta for Developers)
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_WHATSAPP_GROUP_ID=
META_WEBHOOK_VERIFY_TOKEN=turnero_dev_token

# Web Push VAPID (generar: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@newbery.com

# Redis
REDIS_URL=redis://localhost:6379

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
WORKER_URL=http://localhost:3001

# Email
EMAIL_PROVIDER=inbucket
INBUCKET_URL=http://localhost:54324
# En producción usar Resend:
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=
# RESEND_FROM=noreply@newbery.com
